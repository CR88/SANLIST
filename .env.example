# Database Configuration
DATABASE_URL=postgresql://sanctions:sanctions@localhost:5432/sanctions

# Data Sources
SANCTIONS_LIST_URL=https://www.gov.uk/government/publications/the-uk-sanctions-list

# Directories
DATA_DIR=data
LOG_DIR=logs

# Scheduling (Time when daily update runs)
UPDATE_SCHEDULE_HOUR=2
UPDATE_SCHEDULE_MINUTE=0
TIMEZONE=UTC

# Logging
LOG_LEVEL=INFO

# API Configuration (for future use)
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Download Settings
DOWNLOAD_TIMEOUT=60
REQUEST_TIMEOUT=30

# Database Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
